#
# XP/Windows and iOS extensions for FreeRADIUS server/client certs.
# Replace example.com with your domain (iOS 13+, Android 11+, Windows 11 need subjectAltName).
#
[ xpclient_ext ]
extendedKeyUsage = 1.3.6.1.5.5.7.3.2
crlDistributionPoints = URI:http://radius.example.com/ca.crl

[ xpserver_ext ]
extendedKeyUsage = 1.3.6.1.5.5.7.3.1
crlDistributionPoints = URI:http://radius.example.com/ca.crl
subjectAltName = @alt_names
certificatePolicies = 1.3.6.1.4.1.40808.1.3.2

[ alt_names ]
DNS.1 = radius.example.com
DNS.2 = radius.example.com
