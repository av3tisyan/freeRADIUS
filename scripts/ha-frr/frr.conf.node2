! Node 2 (192.168.200.22) – VRRP backup. Merge into /etc/frr/frr.conf.
! Use the same interface name as your 192.168.200.x management address (e.g. ens18).
frr version 9.x
frr defaults traditional
hostname freeradius-node-b
service integrated-vtysh-config
!
interface ens18
 vrrp 23 version 3
 vrrp 23 priority 100
 vrrp 23 advertisement-interval 1000
 vrrp 23 ip 192.168.200.100
!
line vty
!
